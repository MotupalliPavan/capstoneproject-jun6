pipeline {
  agent any
  environment {
    AWS_DEFAULT_REGION = 'us-east-1'
    ECR_REPO           = '<account-id>.dkr.ecr.us-east-1.amazonaws.com/abc-tech'
    IMAGE_TAG          = "abc_tech:${BUILD_NUMBER}"
  }
  stages {
    stage('Checkout') {
      steps { checkout scm }
    }
    stage('Build WAR (Maven)') {
      steps {
        sh 'mvn clean package'
        sh 'cp target/artifact11-1.0-SNAPSHOT.war abc_tech.war'
      }
      post {
        always { junit allowEmptyResults: true, testResults: 'target/surefire-reports/*.xml' }
      }
    }
    stage('Code Coverage (JaCoCo)') {
      steps { jacoco execPattern: 'target/jacoco.exec' }
    }
    stage('Build & Push Docker Image') {
      steps {
        sh 'docker build -t ${IMAGE_TAG} .'
        sh 'aws ecr get-login-password | docker login --username AWS --password-stdin ${ECR_REPO}'
        sh 'docker tag ${IMAGE_TAG} ${ECR_REPO}:${BUILD_NUMBER}'
        sh 'docker push ${ECR_REPO}:${BUILD_NUMBER}'
      }
    }
    stage('Terraform Validate') {
      steps {
        dir('terraform') {
          sh 'terraform init -backend=false'
          sh 'terraform validate'
          sh 'terraform fmt -check'
        }
      }
    }
    stage('IaC Security Scan') {
      steps {
        dir('terraform') { sh 'checkov -d . --compact --output cli' }
      }
    }
    stage('Terraform Plan') {
      steps {
        dir('terraform') { sh 'terraform plan -out=tfplan -var="image_tag=${BUILD_NUMBER}"' }
      }
    }
    stage('Terraform Apply') {
      when { branch 'master' }
      steps {
        dir('terraform') { sh 'terraform apply -auto-approve tfplan' }
      }
    }
  }
  post {
    always { archiveArtifacts artifacts: 'abc_tech.war,terraform/*.tfplan', allowEmptyArchive: true }
  }
}

